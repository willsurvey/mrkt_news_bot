{
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    },
    "api/cron.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/public/index.html"
    }
  ]
}
